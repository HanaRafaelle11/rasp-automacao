# Variáveis de Ambiente — RASP Automação
# Copie este arquivo para .env.local e preencha os valores

# ─── E-mail para receber leads do formulário ──────────────────────────────────
CONTACT_EMAIL=contato@raspautomacao.com.br

# ─── Resend API Key (serviço de e-mail transacional) ─────────────────────────
# Crie uma conta gratuita em https://resend.com e gere uma API key
# O plano gratuito permite 3.000 e-mails/mês
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── WhatsApp (número sem formatação, com DDI) ───────────────────────────────
NEXT_PUBLIC_WHATSAPP=5511963987438

# ─── URL do site em produção ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://raspautomacao.com.br

# ─── Google Analytics 4 (opcional) ───────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google Tag Manager (opcional) ───────────────────────────────────────────
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
