# ============================================================
# .gitignore — RASP Automação (Next.js + TypeScript)
# ============================================================

# ─── Dependências ────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Build / Output Next.js ─────────────────────────────────
.next/
out/
build/
dist/
.swc/

# ─── Cache ───────────────────────────────────────────────────
.cache/
.turbo/
*.tsbuildinfo

# ─── Variáveis de Ambiente (NUNCA commitar) ──────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# ↑ Apenas .env.example deve ir para o repositório

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# ─── Testes / Cobertura ──────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ─── IDEs e Editores ─────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Sistema Operacional ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Certificados e Chaves ───────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Vercel ──────────────────────────────────────────────────
.vercel

# ─── Prisma (se usar no futuro) ──────────────────────────────
# prisma/dev.db
# prisma/test.db

# ─── Arquivos temporários ────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig

# ─── TypeScript gerado automaticamente ──────────────────────
next-env.d.ts
